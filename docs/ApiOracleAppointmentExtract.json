{
  "_meta": {
    "description": "Extracto consolidado de APIs Oracle OHIP para Puente Clos Apalta v2",
    "source_files": [
      "LeisureManagementApis.json (v26.1.0.0)",
      "CustomerManagementApis.json (v26.1.0.0)",
      "CashieringApis.json (v26.1.0.0)"
    ],
    "extracted": "2026-03-27",
    "purpose": "Solo contiene las operaciones y schemas que el bridge necesita para Appointments"
  },
  "apis": {
    "leisureManagement": {
      "description": "OPERA Cloud Leisure Management API v26.1.0.0",
      "operations": {
        "postActivityBooking": {
          "method": "POST",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/activityBookings",
          "pathParams": [
            "hotelId",
            "reservationId"
          ],
          "headers": [
            "Authorization",
            "x-app-key",
            "x-hotelid"
          ],
          "body": {
            "activityBooking": {
              "hotelId": "string (max 20)",
              "reservationId": "uniqueID_Type",
              "profileId": "uniqueID_Type (optional)",
              "activities": "activityList (array of activity objects)"
            }
          }
        },
        "putActivityBooking": {
          "method": "PUT",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/activityBookings",
          "pathParams": [
            "hotelId",
            "reservationId"
          ],
          "description": "Update activity booking for a reservation"
        },
        "deleteActivityBooking": {
          "method": "DELETE",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/activityBookings",
          "pathParams": [
            "hotelId",
            "reservationId"
          ],
          "description": "Cancel activity booking for a reservation"
        }
      },
      "schemas": {
        "activityListItem": {
          "type": {
            "type": "string",
            "description": "Activity type code (e.g. SPA, Golf)"
          },
          "location": {
            "type": "string",
            "description": "Where the activity takes place"
          },
          "name": {
            "type": "array of string (max 200)",
            "description": "Names of participants"
          },
          "numberOfPersons": {
            "type": "integer"
          },
          "timeSpan": {
            "startDateTime": "date-time",
            "endDateTime": "date-time"
          },
          "description": {
            "type": "array of string (max 2000)"
          },
          "note": {
            "type": "array of string (max 2000)"
          },
          "amount": {
            "amount": "number",
            "currencyCode": "string (3 chars)"
          },
          "status": {
            "type": "string",
            "description": "Activity status code"
          }
        }
      }
    },
    "customerManagement": {
      "description": "OPERA Cloud Customer Management Service API v26.1.0.0",
      "operations": {
        "postTrackItItems": {
          "method": "POST",
          "path": "/hotels/{hotelId}/trackItems",
          "pathParams": [
            "hotelId"
          ],
          "headers": [
            "Authorization",
            "x-app-key",
            "x-hotelid"
          ],
          "description": "Creates track it items (service requests / maintenance)"
        },
        "putTrackItItems": {
          "method": "PUT",
          "path": "/hotels/{hotelId}/trackItems",
          "pathParams": [
            "hotelId"
          ],
          "description": "Updates track it items"
        },
        "deleteTrackItItems": {
          "method": "DELETE",
          "path": "/hotels/{hotelId}/trackItems",
          "pathParams": [
            "hotelId"
          ],
          "description": "Deletes track it items"
        },
        "getTrackItItems": {
          "method": "GET",
          "path": "/hotels/{hotelId}/trackItems",
          "pathParams": [
            "hotelId"
          ],
          "description": "Fetches track it items"
        }
      },
      "schemas": {
        "trackItItemType": {
          "hotelId": "string (max 20)",
          "trackItId": "unique ID",
          "ticketNumber": "string (max 80)",
          "referenceNumber": "string (max 20)",
          "type": "trackItType (code + description)",
          "action": "trackItActionType (code + description)",
          "location": "codeDescriptionType (code + description)",
          "quantity": "integer",
          "followUpDate": "date",
          "description": "string (max 2000)",
          "assignedTo": "applicationUserType",
          "reservationInfo": "trackItReservationInfoType (links to reservation)"
        }
      }
    },
    "cashiering": {
      "description": "OPERA Cloud Cashiering API v26.1.0.0",
      "operations": {
        "postBillingCharges": {
          "method": "POST",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/charges",
          "pathParams": [
            "hotelId",
            "reservationId"
          ],
          "headers": [
            "Authorization",
            "x-app-key",
            "x-hotelid"
          ],
          "description": "Post charge to a reservation folio"
        },
        "getBillingCharges": {
          "method": "GET",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/charges",
          "pathParams": [
            "hotelId",
            "reservationId"
          ],
          "description": "Get billing charges for a reservation"
        }
      },
      "schemas": {
        "billingChargesCriteria": {
          "hotelId": "string (max 20)",
          "reservationId": "reservationId object",
          "cashierId": "cashierId",
          "charges": "array of chargeCriteria"
        },
        "chargeCriteria": {
          "transactionCode": "string (max 80) — e.g. 2004=Breakfast, 2010=Lunch, 2020=Dinner",
          "articleCode": "string (max 20) — optional article ID",
          "price": {
            "amount": "number",
            "currencyCode": "string (3 chars)"
          },
          "postingQuantity": "integer",
          "postingReference": "string (max 2000) — user-defined reference",
          "postingRemark": "string (max 2000) — user-defined remark (meal description goes here)",
          "folioWindowNo": "integer — which folio window (0-7)",
          "applyRoutingInstructions": "boolean",
          "usePackageAllowance": "boolean"
        }
      },
      "transactionCodesForMeals_Outlet1": {
        "breakfast_food": "2004",
        "lunch_food": "2010",
        "dinner_food": "2020",
        "breakfast_alcoholic_bev": "2002",
        "breakfast_nonalcoholic_bev": "2014",
        "lunch_nonalcoholic_bev": "2011",
        "lunch_alcoholic_bev": "2012",
        "dinner_nonalcoholic_bev": "2021",
        "dinner_alcoholic_bev": "2022",
        "miscellaneous": "2050"
      }
    },
    "guestMessages": {
      "description": "Part of OPERA Cloud Reservation API (ApiOracleReservations.json) — already in Knowledge",
      "operations": {
        "postGuestMessages": {
          "method": "POST",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/guestMessages",
          "pathParams": [
            "hotelId",
            "reservationId"
          ]
        },
        "putResvGuestMessages": {
          "method": "PUT",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/guestMessages"
        },
        "putGuestMessages": {
          "method": "PUT",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/guestMessages/{guestMessageId}"
        },
        "deleteGuestMessages": {
          "method": "DELETE",
          "path": "/hotels/{hotelId}/reservations/{reservationId}/guestMessages/{guestMessageId}"
        }
      },
      "schemas": {
        "guestMessageType": {
          "messageText": "string (max 2000)",
          "messageDate": "date-time",
          "typeOfMessage": "Voice | Text",
          "recipient": "string (max 20000)",
          "operator": "string (max 256)"
        }
      }
    }
  },
